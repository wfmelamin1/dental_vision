{
  "name": "Dental Perio Measurement",
  "module": "Dental Vision",
  "doctype": "DocType",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {"fieldname": "tooth_number", "fieldtype": "Int", "label": "Tooth #", "reqd": 1, "in_list_view": 1, "description": "1-32 Universal"},
    {"fieldname": "sequence_type", "fieldtype": "Select", "label": "Sequence", "options": "Facial\nLingual", "reqd": 1, "in_list_view": 1},
    {"fieldname": "pd_section", "fieldtype": "Section Break", "label": "Probing Depths (mm)"},
    {"fieldname": "pd_1", "fieldtype": "Int", "label": "PD-1 (MB/ML)", "in_list_view": 1, "description": "0-12mm"},
    {"fieldname": "pd_2", "fieldtype": "Int", "label": "PD-2 (B/L)", "in_list_view": 1},
    {"fieldname": "pd_3", "fieldtype": "Int", "label": "PD-3 (DB/DL)", "in_list_view": 1},
    {"fieldname": "gm_section", "fieldtype": "Section Break", "label": "Gingival Margin (mm, negative=recession)"},
    {"fieldname": "gm_1", "fieldtype": "Int", "label": "GM-1"},
    {"fieldname": "gm_2", "fieldtype": "Int", "label": "GM-2"},
    {"fieldname": "gm_3", "fieldtype": "Int", "label": "GM-3"},
    {"fieldname": "cal_section", "fieldtype": "Section Break", "label": "Clinical Attachment Loss (auto-calc)"},
    {"fieldname": "cal_1", "fieldtype": "Float", "label": "CAL-1", "read_only": 1},
    {"fieldname": "cal_2", "fieldtype": "Float", "label": "CAL-2", "read_only": 1},
    {"fieldname": "cal_3", "fieldtype": "Float", "label": "CAL-3", "read_only": 1},
    {"fieldname": "bop_section", "fieldtype": "Section Break", "label": "Bleeding on Probing"},
    {"fieldname": "bop_1", "fieldtype": "Check", "label": "BOP-1", "in_list_view": 1},
    {"fieldname": "bop_2", "fieldtype": "Check", "label": "BOP-2"},
    {"fieldname": "bop_3", "fieldtype": "Check", "label": "BOP-3"},
    {"fieldname": "sup_1", "fieldtype": "Check", "label": "Suppuration-1"},
    {"fieldname": "sup_2", "fieldtype": "Check", "label": "Suppuration-2"},
    {"fieldname": "sup_3", "fieldtype": "Check", "label": "Suppuration-3"},
    {"fieldname": "plaque_section", "fieldtype": "Section Break", "label": "Plaque"},
    {"fieldname": "plaque_1", "fieldtype": "Check", "label": "Plaque-1"},
    {"fieldname": "plaque_2", "fieldtype": "Check", "label": "Plaque-2"},
    {"fieldname": "plaque_3", "fieldtype": "Check", "label": "Plaque-3"},
    {"fieldname": "mobility_section", "fieldtype": "Section Break", "label": "Mobility & Furcation"},
    {"fieldname": "mobility", "fieldtype": "Select", "label": "Mobility", "options": "0\n1\n2\n3", "in_list_view": 1},
    {"fieldname": "furcation_b", "fieldtype": "Select", "label": "Furcation Buccal", "options": "0\n1\n2\n3"},
    {"fieldname": "furcation_l", "fieldtype": "Select", "label": "Furcation Lingual", "options": "0\n1\n2\n3"},
    {"fieldname": "mgj_section", "fieldtype": "Section Break", "label": "Mucogingival Junction (mm)"},
    {"fieldname": "mgj_1", "fieldtype": "Int", "label": "MGJ-1"},
    {"fieldname": "mgj_2", "fieldtype": "Int", "label": "MGJ-2"},
    {"fieldname": "mgj_3", "fieldtype": "Int", "label": "MGJ-3"}
  ]
}
