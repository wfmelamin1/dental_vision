{
  "name": "Dental Procedure",
  "module": "Dental Vision",
  "doctype": "DocType",
  "autoname": "format:PROC-{YYYY}-{#####}",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {"fieldname": "patient", "fieldtype": "Link", "label": "Patient", "options": "Patient", "reqd": 1, "in_list_view": 1},
    {"fieldname": "patient_name", "fieldtype": "Data", "label": "Patient Name", "fetch_from": "patient.full_name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "procedure_date", "fieldtype": "Date", "label": "Procedure Date", "reqd": 1, "default": "Today", "in_list_view": 1},
    {"fieldname": "procedure_code", "fieldtype": "Link", "label": "CDT Code", "options": "Procedure Code", "reqd": 1, "in_list_view": 1},
    {"fieldname": "procedure_name", "fieldtype": "Data", "label": "Procedure Description", "fetch_from": "procedure_code.procedure_name", "read_only": 1},
    {"fieldname": "column_break_1", "fieldtype": "Column Break"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status",
      "options": "Treatment Planned\nComplete\nExisting Current\nExisting Other\nReferred\nCondition\nDeleted",
      "default": "Treatment Planned", "reqd": 1, "in_list_view": 1},
    {"fieldname": "provider", "fieldtype": "Link", "label": "Provider", "options": "Dental Provider", "reqd": 1},
    {"fieldname": "appointment", "fieldtype": "Link", "label": "Linked Appointment", "options": "Appointment"},
    {"fieldname": "treatment_plan", "fieldtype": "Link", "label": "Treatment Plan", "options": "Treatment Plan"},
    {"fieldname": "tooth_section", "fieldtype": "Section Break", "label": "Tooth Details"},
    {"fieldname": "tooth_number", "fieldtype": "Data", "label": "Tooth Number", "description": "Universal: 1-32 or A-T | FDI: 11-48"},
    {"fieldname": "tooth_surface", "fieldtype": "Data", "label": "Surface(s)", "description": "e.g. MOD, B, MO — Mesial/Occlusal/Distal/Buccal/Lingual"},
    {"fieldname": "quadrant", "fieldtype": "Select", "label": "Quadrant", "options": "\nUR\nUL\nLR\nLL"},
    {"fieldname": "arch", "fieldtype": "Select", "label": "Arch", "options": "\nMaxillary\nMandibular"},
    {"fieldname": "column_break_2", "fieldtype": "Column Break"},
    {"fieldname": "diagnosis", "fieldtype": "Data", "label": "Diagnosis (ICD-10)"},
    {"fieldname": "priority", "fieldtype": "Int", "label": "Priority (1=Urgent)", "default": 3},
    {"fieldname": "is_hygiene_procedure", "fieldtype": "Check", "label": "Hygiene Procedure"},
    {"fieldname": "billing_section", "fieldtype": "Section Break", "label": "Fees & Insurance"},
    {"fieldname": "fee", "fieldtype": "Currency", "label": "Fee (UCR)", "in_list_view": 1},
    {"fieldname": "insurance_estimate_primary", "fieldtype": "Currency", "label": "Primary Insurance Est."},
    {"fieldname": "insurance_estimate_secondary", "fieldtype": "Currency", "label": "Secondary Insurance Est."},
    {"fieldname": "patient_estimate", "fieldtype": "Currency", "label": "Patient Estimate"},
    {"fieldname": "column_break_3", "fieldtype": "Column Break"},
    {"fieldname": "billed_to_invoice", "fieldtype": "Check", "label": "Billed", "read_only": 1},
    {"fieldname": "sales_invoice", "fieldtype": "Link", "label": "Sales Invoice", "options": "Sales Invoice", "read_only": 1},
    {"fieldname": "insurance_claim", "fieldtype": "Link", "label": "Insurance Claim", "options": "Insurance Claim", "read_only": 1},
    {"fieldname": "date_completed", "fieldtype": "Date", "label": "Date Completed"},
    {"fieldname": "clinical_section", "fieldtype": "Section Break", "label": "Clinical Notes"},
    {"fieldname": "procedure_note", "fieldtype": "Text Editor", "label": "Procedure Note / Progress Note",
      "description": "Clinical note — required before submitting completed procedures"},
    {"fieldname": "auto_note_template", "fieldtype": "Data", "label": "Auto Note Used"}
  ],
  "permissions": [
    {"role": "Dentist", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Dental Hygienist", "read": 1, "write": 1, "create": 1},
    {"role": "Dental Receptionist", "read": 1},
    {"role": "Dental Billing", "read": 1},
    {"role": "Dental Office Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1}
  ]
}
