{
  "name": "Patient",
  "module": "Dental Vision",
  "doctype": "DocType",
  "engine": "InnoDB",
  "field_order": [
    "basic_info_section",
    "patient_id",
    "first_name",
    "last_name",
    "full_name",
    "column_break_1",
    "date_of_birth",
    "age",
    "gender",
    "patient_photo",
    "contact_section",
    "email",
    "mobile_phone",
    "home_phone",
    "work_phone",
    "column_break_2",
    "address_line_1",
    "address_line_2",
    "city",
    "state",
    "zip_code",
    "country",
    "medical_section",
    "blood_group",
    "allergies",
    "medical_alerts",
    "current_medications",
    "column_break_3",
    "medical_history_notes",
    "smoking_status",
    "pregnancy_status",
    "primary_care_physician",
    "insurance_section",
    "primary_insurance_provider",
    "primary_insurance_id",
    "primary_group_number",
    "column_break_4",
    "secondary_insurance_provider",
    "secondary_insurance_id",
    "responsible_party",
    "emergency_section",
    "emergency_contact_name",
    "emergency_contact_phone",
    "emergency_contact_relation",
    "dental_section",
    "referring_provider",
    "preferred_provider",
    "patient_status",
    "first_visit_date",
    "last_visit_date",
    "recall_interval",
    "next_recall_date",
    "column_break_5",
    "credit_balance",
    "billing_type",
    "collection_note",
    "system_section",
    "linked_user",
    "created_from_opendental",
    "opendental_patient_num",
    "hipaa_signature_date",
    "hipaa_signature_obtained"
  ],
  "fields": [
    {"fieldname": "basic_info_section", "fieldtype": "Section Break", "label": "Basic Information"},
    {"fieldname": "patient_id", "fieldtype": "Data", "label": "Patient ID", "unique": 1, "read_only": 1, "description": "Auto-generated unique patient identifier"},
    {"fieldname": "first_name", "fieldtype": "Data", "label": "First Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "last_name", "fieldtype": "Data", "label": "Last Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "full_name", "fieldtype": "Data", "label": "Full Name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "column_break_1", "fieldtype": "Column Break"},
    {"fieldname": "date_of_birth", "fieldtype": "Date", "label": "Date of Birth", "reqd": 1, "in_list_view": 1},
    {"fieldname": "age", "fieldtype": "Int", "label": "Age", "read_only": 1},
    {"fieldname": "gender", "fieldtype": "Select", "label": "Gender", "options": "\nMale\nFemale\nOther\nPrefer Not to Say", "reqd": 1},
    {"fieldname": "patient_photo", "fieldtype": "Attach Image", "label": "Patient Photo"},

    {"fieldname": "contact_section", "fieldtype": "Section Break", "label": "Contact Information"},
    {"fieldname": "email", "fieldtype": "Data", "label": "Email", "options": "Email"},
    {"fieldname": "mobile_phone", "fieldtype": "Data", "label": "Mobile Phone", "in_list_view": 1},
    {"fieldname": "home_phone", "fieldtype": "Data", "label": "Home Phone"},
    {"fieldname": "work_phone", "fieldtype": "Data", "label": "Work Phone"},
    {"fieldname": "column_break_2", "fieldtype": "Column Break"},
    {"fieldname": "address_line_1", "fieldtype": "Data", "label": "Address Line 1"},
    {"fieldname": "address_line_2", "fieldtype": "Data", "label": "Address Line 2"},
    {"fieldname": "city", "fieldtype": "Data", "label": "City"},
    {"fieldname": "state", "fieldtype": "Data", "label": "State / Province"},
    {"fieldname": "zip_code", "fieldtype": "Data", "label": "ZIP / Postal Code"},
    {"fieldname": "country", "fieldtype": "Link", "label": "Country", "options": "Country"},

    {"fieldname": "medical_section", "fieldtype": "Section Break", "label": "Medical History"},
    {"fieldname": "blood_group", "fieldtype": "Select", "label": "Blood Group", "options": "\nA+\nA-\nB+\nB-\nAB+\nAB-\nO+\nO-\nUnknown"},
    {"fieldname": "allergies", "fieldtype": "Small Text", "label": "Allergies", "description": "List all known allergies, including drug allergies"},
    {"fieldname": "medical_alerts", "fieldtype": "Small Text", "label": "Medical Alerts", "description": "Critical flags shown prominently on chart (e.g., Penicillin allergy, Warfarin)"},
    {"fieldname": "current_medications", "fieldtype": "Small Text", "label": "Current Medications"},
    {"fieldname": "column_break_3", "fieldtype": "Column Break"},
    {"fieldname": "medical_history_notes", "fieldtype": "Text Editor", "label": "Medical History Notes"},
    {"fieldname": "smoking_status", "fieldtype": "Select", "label": "Smoking Status", "options": "\nNever\nFormer\nCurrent - Light (<10/day)\nCurrent - Heavy (10+/day)\nE-Cigarette"},
    {"fieldname": "pregnancy_status", "fieldtype": "Select", "label": "Pregnancy Status", "options": "\nNot Applicable\nPossibly Pregnant\nCurrently Pregnant\nBreastfeeding"},
    {"fieldname": "primary_care_physician", "fieldtype": "Data", "label": "Primary Care Physician"},

    {"fieldname": "insurance_section", "fieldtype": "Section Break", "label": "Insurance"},
    {"fieldname": "primary_insurance_provider", "fieldtype": "Link", "label": "Primary Insurance", "options": "Insurance Provider"},
    {"fieldname": "primary_insurance_id", "fieldtype": "Data", "label": "Primary Member ID"},
    {"fieldname": "primary_group_number", "fieldtype": "Data", "label": "Primary Group #"},
    {"fieldname": "column_break_4", "fieldtype": "Column Break"},
    {"fieldname": "secondary_insurance_provider", "fieldtype": "Link", "label": "Secondary Insurance", "options": "Insurance Provider"},
    {"fieldname": "secondary_insurance_id", "fieldtype": "Data", "label": "Secondary Member ID"},
    {"fieldname": "responsible_party", "fieldtype": "Link", "label": "Responsible Party (Guarantor)", "options": "Patient"},

    {"fieldname": "emergency_section", "fieldtype": "Section Break", "label": "Emergency Contact"},
    {"fieldname": "emergency_contact_name", "fieldtype": "Data", "label": "Emergency Contact Name"},
    {"fieldname": "emergency_contact_phone", "fieldtype": "Data", "label": "Emergency Contact Phone"},
    {"fieldname": "emergency_contact_relation", "fieldtype": "Data", "label": "Relationship"},

    {"fieldname": "dental_section", "fieldtype": "Section Break", "label": "Dental Practice Info"},
    {"fieldname": "referring_provider", "fieldtype": "Link", "label": "Referred By", "options": "Dental Provider"},
    {"fieldname": "preferred_provider", "fieldtype": "Link", "label": "Primary Dentist", "options": "Dental Provider"},
    {"fieldname": "patient_status", "fieldtype": "Select", "label": "Patient Status", "options": "Active\nInactive\nDeceased\nArchived", "default": "Active", "in_list_view": 1},
    {"fieldname": "first_visit_date", "fieldtype": "Date", "label": "First Visit Date"},
    {"fieldname": "last_visit_date", "fieldtype": "Date", "label": "Last Visit Date"},
    {"fieldname": "recall_interval", "fieldtype": "Int", "label": "Recall Interval (months)", "default": 6},
    {"fieldname": "next_recall_date", "fieldtype": "Date", "label": "Next Recall Date"},
    {"fieldname": "column_break_5", "fieldtype": "Column Break"},
    {"fieldname": "credit_balance", "fieldtype": "Currency", "label": "Account Balance", "read_only": 1},
    {"fieldname": "billing_type", "fieldtype": "Select", "label": "Billing Type", "options": "\nInsurance Primary\nCash Patient\nSliding Scale\nWriteoff"},
    {"fieldname": "collection_note", "fieldtype": "Small Text", "label": "Collection / Billing Note"},

    {"fieldname": "system_section", "fieldtype": "Section Break", "label": "System"},
    {"fieldname": "linked_user", "fieldtype": "Link", "label": "Linked Frappe User", "options": "User"},
    {"fieldname": "created_from_opendental", "fieldtype": "Check", "label": "Migrated from OpenDental"},
    {"fieldname": "opendental_patient_num", "fieldtype": "Int", "label": "OpenDental PatNum"},
    {"fieldname": "hipaa_signature_date", "fieldtype": "Date", "label": "HIPAA Signature Date"},
    {"fieldname": "hipaa_signature_obtained", "fieldtype": "Check", "label": "HIPAA Signature Obtained"}
  ],
  "title_field": "full_name",
  "search_fields": "full_name,patient_id,mobile_phone,email",
  "track_changes": 1,
  "track_seen": 1,
  "autoname": "field:patient_id",
  "permissions": [
    {"role": "Dentist", "read": 1, "write": 1, "create": 1},
    {"role": "Dental Receptionist", "read": 1, "write": 1, "create": 1},
    {"role": "Dental Hygienist", "read": 1, "write": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1}
  ]
}
